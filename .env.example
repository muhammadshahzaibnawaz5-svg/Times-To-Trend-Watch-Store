# Public base URL of the deployed storefront
NEXT_PUBLIC_BASE_URL=https://adnanwatchstore.com

# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key for trusted server operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe secret key for server-side payment operations
STRIPE_SECRET_KEY=sk_test_example

# Stripe publishable key for client-side checkout integrations
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_example

# Stripe webhook signing secret
STRIPE_WEBHOOK_SECRET=whsec_example

# ImgBB API key for product image hosting
IMGBB_API_KEY=your-imgbb-api-key

# Resend API key for sending contact form emails
RESEND_API_KEY=re_xxxxx

# Where contact form emails are sent
CONTACT_EMAIL_TO=your-email@gmail.com

# Verified sender in Resend (use onboarding@resend.dev for testing)
CONTACT_EMAIL_FROM=onboarding@resend.dev
